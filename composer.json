{
  "name": "amnestywebsite/humanity-theme",
  "description": "Amnesty International France WordPress website",
  "type": "project",
  "license": "none",
  "minimum-stability": "stable",
  "require-dev": {
    "bigbite/phpcs-config": "v3.0.0",
    "friendsofphp/php-cs-fixer": "^3.87",
    "symfony/var-dumper": "^7.3",
    "phpstan/phpstan": "^2.2",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "php-stubs/wp-cli-stubs": "2.12.0",
    "phpunit/phpunit": "^11.5",
    "php-stubs/acf-pro-stubs": "^6.8"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "scripts": {
    "analyse": "phpstan analyze",
    "cs": "php-cs-fixer fix --config=.php-cs-fixer.php --diff --dry-run",
    "lint": "./vendor/bin/phpcs wp-content/themes/humanity-theme",
    "test": "phpunit",
    "test:salesforce": "phpunit --testsuite Salesforce",
    "test:donor-space": "phpunit --testsuite DonorSpace",
    "test:petitions": "phpunit --testsuite Petitions",
    "test:salesforce-sync": "phpunit --testsuite SalesforceSync",
    "makePot": "wp i18n make-pot wp-content/themes/humanity-theme wp-content/themes/humanity-theme/languages/amnesty.pot --domain=amnesty --exclude=private",
    "updatePoMo": [
      "wp i18n update-po wp-content/themes/humanity-theme/languages/amnesty.pot",
      "wp i18n make-mo wp-content/themes/humanity-theme/languages",
      "wp i18n make-json wp-content/themes/humanity-theme/languages --no-purge"
    ]
  },
  "scripts-descriptions": {
    "analyse": "Runs PHPStan static analysis",
    "cs": "Runs PHP-CS-Fixer checks",
    "lint": "Runs PHP coding standard checks",
    "test": "Runs all PHP tests",
    "test:salesforce": "Runs focused Salesforce PHP tests",
    "test:donor-space": "Runs donor/member space PHP tests",
    "test:petitions": "Runs petitions and urgent action PHP tests",
    "test:salesforce-sync": "Runs the CLI signature bulk-sync integration test (~30s, real sleep() in poll_job_state())",
    "makePot": "Re-generates the POT language file",
    "updatePoMo": "Updates PO, MO, and JSON translation files"
  },
  "require": {
    "php": ">=8.2",
    "ext-mbstring": "*",
    "php-cs-fixer/diff": "^2.0",
    "vlucas/phpdotenv": "^5.6"
  }
}
